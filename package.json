{
  "name": "colegio_cfuturo",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "dev:client": "npm --prefix client run dev",
    "build": "tsc",
    "build:client": "npm --prefix client run build",
    "build:all": "tsc && npm --prefix client run build",
    "stage:dist": "git add -f dist client/dist",
    "prepare:dist": "tsc && npm --prefix client run build && git add -f dist client/dist",
    "typecheck": "tsc --noEmit",
    "start": "node dist/server.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^1.4.13",
    "@types/node": "^25.5.0",
    "@types/nodemailer": "^6.4.17",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1022.0",
    "@aws-sdk/s3-request-presigner": "^3.1022.0",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "mysql2": "^3.15.2",
    "nodemailer": "^8.0.5",
    "zod": "^4.1.9"
  }
}
